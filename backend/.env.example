# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=VPN Remna API
APP_VERSION=1.0.0
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY
ALLOWED_ORIGINS=["https://your-miniapp-domain.com","https://t.me"]

# ── MySQL Database ─────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=vpnremna
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=vpnremna
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAF_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: secret token for Telegram webhook verification
TELEGRAM_WEBHOOK_SECRET=

# ── Remnawave Panel ───────────────────────────────────────────────────────────
REMNAWAVE_URL=https://your-remnawave-panel.example.com
REMNAWAVE_API_KEY=YOUR_REMNAWAVE_JWT_API_KEY_HERE
# Optional: shared secret for Remnawave webhook signature verification
REMNAWAVE_WEBHOOK_SECRET=

# ── Admin JWT ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── YooKassa ──────────────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Referral ──────────────────────────────────────────────────────────────────
REFERRAL_CASHBACK_PERCENT=10.0
REFERRAL_MIN_WITHDRAWAL=100.0

# ── Trial subscription ────────────────────────────────────────────────────────
TRIAL_ENABLED=true
TRIAL_DAYS=3
# Leave empty for unlimited trial traffic
TRIAL_TRAFFIC_GB=

# ── Notification thresholds ───────────────────────────────────────────────────
NOTIFY_SUBSCRIPTION_EXPIRY_DAYS=[3,1]
NOTIFY_TRAFFIC_THRESHOLD_PERCENT=80
